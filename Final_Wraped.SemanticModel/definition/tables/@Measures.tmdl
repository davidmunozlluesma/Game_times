table @Measures
	lineageTag: 6b496767-6063-4a86-9379-a30e9fea642c

	measure 'Duracion Total' =
			// Sums the 'Duración' column from the Games table to get the total duration.
			SUM(Games[Duración])
		lineageTag: 942b9507-60f5-4b6f-b5cc-6758dbcc1663

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Top 1 Game' = ```
			 		// Returns the game with the highest value in [Total Horas Num].
			 		// ALL removes any filter on the games.
			 		TOPN(1, ALL(Games[Game]), [Total Horas Num])
			```
		displayFolder: Top
		lineageTag: b6bcc28c-7db4-40b4-828c-3b4ba0f6ccba

	measure 'Total Horas y Minutos New' = ```
			// Calculates the total duration by summing the difference between start and finish hour for each row.
			VAR _Duration =
				SUMX(
					Games,
					// Gets the start and finish hour for each game
					VAR _Start = Games[Start Hour]
					VAR _Finish = Games[Finish Hour]
					// If the finish hour is less than the start hour, adds 1 (crosses midnight)
					RETURN 
						IF(_Finish < _Start, _Finish + 1 - _Start, _Finish - _Start)
				)
			// Converts the total duration (in days) to hours and minutes
			VAR TotalHours = INT(_Duration * 24)
			VAR TotalMinutes = INT((_Duration * 24 - TotalHours) * 60)
			RETURN
			// If the duration is 0, returns BLANK, otherwise returns the text with hours and minutes
			IF(
				_Duration = 0,
				BLANK(),
				TotalHours & "h " & FORMAT(TotalMinutes, "00") & "m"
			)
			```
		lineageTag: dd971678-4d7b-435f-8642-97873b306092

	measure 'Total Horas Num' =
			// Calculates the sum of the difference between start and finish hour for each game.
			VAR _Duration =
				SUMX(
					Games,
					// Gets the start and finish hour for each game
					VAR _Start = Games[Start Hour]
					VAR _Finish = Games[Finish Hour]
					// If the finish hour is less than the start hour, adds 1 (crosses midnight)
					RETURN
						IF(_Finish < _Start, _Finish + 1 - _Start, _Finish - _Start)
				)
			// Converts the total duration (in days) to hours
			RETURN
			_Duration * 24
		lineageTag: 99b732fe-9cf6-4676-b62e-5cf182e17af4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ranking Games by Duration' =
			// Assigns a ranking to each game according to the total hours played, from highest to lowest.
			RANKX(
				ALL(Games[Game]),
				[Total Horas Num],
				,
				DESC
			)
		formatString: 0
		lineageTag: 2b054a10-a5ca-4cac-969b-a21a4f122cd3

	measure 'Top 2 Game' =
			// Returns the name of the game that is in position 2 of the ranking by duration.
			VAR RankingTable =
				ADDCOLUMNS(
					ALL(Games[Game]),
					"Rk", [Ranking Games by Duration]
				)
			RETURN
			CALCULATE(
				SELECTEDVALUE(Games[Game]),
				FILTER(RankingTable, [Rk] = 2)
			)
		displayFolder: Top
		lineageTag: f2e10095-61f1-48a3-b078-5003b976eac3

