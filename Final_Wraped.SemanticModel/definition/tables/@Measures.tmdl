	measure YTD =
			// Calculates the total hours played year-to-date (YTD) using the calendar.
			CALCULATE(
			    [Total Horas Num],
			    DATESYTD(Calendario[Date], "31/12")
			)
		lineageTag: 3e45776d-9ae6-429e-8012-1122dcabf572

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Sesions =
			// Counts the number of rows in the Games table, i.e., the number of sessions.
			COUNTROWS(Games)
		formatString: 0
		lineageTag: ea0e2e69-92e3-49b2-92bd-8a8e69745308

	measure 'Hour AV' = ```
			// Calculates the average session duration in hours and minutes.
			VAR _Duration =
				AVERAGEX(
					Games,
					// Gets the start and finish hour for each game
					VAR _Start = Games[Start Hour]
					VAR _Finish = Games[Finish Hour]
					// If the finish hour is less than the start hour, adds 1 (crosses midnight)
					RETURN 
						IF(_Finish < _Start, _Finish + 1 - _Start, _Finish - _Start)
				)
			// Converts the average duration (in days) to hours and minutes
			VAR TotalHours = INT(_Duration * 24)
			VAR TotalMinutes = INT((_Duration * 24 - TotalHours) * 60)
			RETURN
			TotalHours & "h " & FORMAT(TotalMinutes, "00") & "m"
			```
		lineageTag: 1b41fc45-ab25-48af-b339-8472b15fe64b

