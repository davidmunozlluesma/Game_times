	measure YTD =
			
			CALCULATE(
			    [Total Horas Num],
			    DATESYTD(Calendario[Date], "31/12")
			)
		lineageTag: 3e45776d-9ae6-429e-8012-1122dcabf572

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Sesions = COUNTROWS(Games)
		formatString: 0
		lineageTag: ea0e2e69-92e3-49b2-92bd-8a8e69745308

	measure 'Hour Average' = ```
			
			VAR _Duracion =
			    AVERAGEX(
			        Games,
			        VAR _Start = Games[Start Hour]
			        VAR _Finish = Games[Finish Hour]
			        RETURN 
			            IF(_Finish < _Start, _Finish + 1 - _Start, _Finish - _Start)
			    )
			VAR TotalHoras = INT(_Duracion * 24)
			VAR TotalMinutos = INT((_Duracion * 24 - TotalHoras) * 60)
			RETURN
			TotalHoras & "h " & FORMAT(TotalMinutos, "00") & "m"
			```
		lineageTag: 1b41fc45-ab25-48af-b339-8472b15fe64b

