table @Measures
	lineageTag: 6b496767-6063-4a86-9379-a30e9fea642c

	measure 'Duracion Total' = ```
			
			SUM(Games[Duración])
			
			```
		lineageTag: 942b9507-60f5-4b6f-b5cc-6758dbcc1663

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Top 1 Jugo' =
			
			TOPN(1, ALL(Games[Game]), [Total Horas Num])
		displayFolder: Top
		lineageTag: b6bcc28c-7db4-40b4-828c-3b4ba0f6ccba

	measure 'Total Hours Text' = ```
			
			VAR _Duracion =
			    SUMX(
			        Games,
			        VAR _Start = Games[Start Hour]
			        VAR _Finish = Games[Finish Hour]
			        RETURN 
			            IF(_Finish < _Start, _Finish + 1 - _Start, _Finish - _Start)
			    )
			VAR TotalHoras = INT(_Duracion * 24)
			VAR TotalMinutos = INT((_Duracion * 24 - TotalHoras) * 60)
			RETURN
			IF(
			    _Duracion = 0,
			    BLANK(),
			    TotalHoras & "h " & FORMAT(TotalMinutos, "00") & "m"
			)
			```
		lineageTag: dd971678-4d7b-435f-8642-97873b306092

	measure 'Total Hours Num' = ```
			
			VAR _Duracion =
			    SUMX(
			        Games,
			        VAR _Start = Games[Start Hour]
			        VAR _Finish = Games[Finish Hour]
			        RETURN
			            IF(_Finish < _Start, _Finish + 1 - _Start, _Finish - _Start)
			    )
			RETURN
			_Duracion * 24
			
			```
		lineageTag: 99b732fe-9cf6-4676-b62e-5cf182e17af4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ranking Juegos por Duracion' = ```
			
			RANKX(
			    ALL(Games[Game]),
			    [Total Horas Num],
			    ,
			    DESC
			)
			
			```
		formatString: 0
		lineageTag: 2b054a10-a5ca-4cac-969b-a21a4f122cd3

	measure 'Top 2 Juego' = ```
			
			VAR TablaRanking =
			    ADDCOLUMNS(
			        ALL(Games[Game]),
			        "Rk", [Ranking Juegos por Duracion]
			    )
			RETURN
			CALCULATE(
			    SELECTEDVALUE(Games[Game]),
			    FILTER(TablaRanking, [Rk] = 2)
			)
			
			```
		displayFolder: Top
		lineageTag: f2e10095-61f1-48a3-b078-5003b976eac3

