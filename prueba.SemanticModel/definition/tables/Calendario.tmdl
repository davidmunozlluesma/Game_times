	partition Calendario = calculated
		mode: import
		source = ```
				
				VAR FechaInicio = DATE(2024,1,1)
				VAR FechaFin    = DATE(2030,12,31)
				RETURN
				ADDCOLUMNS(
				    CALENDAR(FechaInicio, FechaFin),
				    "Mes", FORMAT([Date],"MMMM"),
				    "Mes Numero", MONTH([Date]),
				    "Día", FORMAT([Date],"dddd"),
				    "Día Semana Numero", WEEKDAY([Date], 2),
				    "Día Numero", DAY([Date]),
				    "Año", YEAR([Date]),
				    "Trimestre", "Q" & FORMAT([Date],"Q"),
				    "Trimestre Numero", QUARTER([Date]),
				    "Semana Numero", WEEKNUM([Date],2),
				    "Es Finde Semana", IF(WEEKDAY([Date],2) > 5, TRUE(), FALSE())
				)
				
				```

	annotation PBI_Id = 3b0c318420b74ab9a4dd076e70f3f7f1

